@using System.Linq
@using System.Threading.Tasks
@using BlazorApp.Models
@using BlazorApp.Services
@using MudBlazor
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Cambiar contraseña</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="7">
                @if (!string.IsNullOrWhiteSpace(feedbackMessage))
                {
                    <MudAlert Severity="@feedbackSeverity" Variant="Variant.Filled" Class="mb-4">@feedbackMessage</MudAlert>
                }

                <MudForm Model="request">
                    <MudTextField T="string" @bind-Value="request.ContrasenaActual" Label="Contraseña actual" Variant="Variant.Outlined" InputType="InputType.Password" FullWidth="true" Class="mb-3" />
                    <MudTextField T="string" @bind-Value="request.NuevaContrasena" Label="Nueva contraseña" Variant="Variant.Outlined" InputType="InputType.Password" FullWidth="true" Class="mb-3" />
                    <MudTextField T="string" @bind-Value="request.ConfirmarNuevaContrasena" Label="Confirmar nueva contraseña" Variant="Variant.Outlined" InputType="InputType.Password" FullWidth="true" />
                </MudForm>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Outlined="true" Class="pa-4 h-100">
                    <MudText Typo="Typo.subtitle1" GutterBottom="true">Políticas de contraseña</MudText>
                    <div class="d-flex flex-column gap-2">
                        <MudChip T="string" Text="Mínimo 12 caracteres" Color="@(request.NuevaContrasena.Length >= 12 ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="Al menos una mayúscula" Color="@(HasUppercase ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="Al menos una minúscula" Color="@(HasLowercase ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="Al menos un número" Color="@(HasNumber ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="Al menos un carácter especial" Color="@(HasSpecialCharacter ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="No repetir contraseñas anteriores" Color="Color.Info" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="No usar datos personales" Color="Color.Info" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="Confirmación debe coincidir" Color="@(PasswordsMatch ? Color.Success : Color.Default)" Variant="Variant.Outlined" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
<MudButton OnClick="SubmitAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="@isProcessing">
            @if (isProcessing)
            {
                <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" />
                <MudText Inline="true">Actualizando</MudText>
            }
            else
            {
                <MudText Inline="true">Actualizar contraseña</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private ChangePasswordRequestDto request = new();
    private string feedbackMessage = string.Empty;
    private Severity feedbackSeverity = Severity.Info;
    private bool isProcessing;

    private bool HasUppercase => request.NuevaContrasena.Any(char.IsUpper);
    private bool HasLowercase => request.NuevaContrasena.Any(char.IsLower);
    private bool HasNumber => request.NuevaContrasena.Any(char.IsDigit);
    private bool HasSpecialCharacter => request.NuevaContrasena.Any(ch => !char.IsLetterOrDigit(ch));
    private bool PasswordsMatch => !string.IsNullOrWhiteSpace(request.NuevaContrasena) && request.NuevaContrasena == request.ConfirmarNuevaContrasena;

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        isProcessing = true;
        var response = await AuthService.ChangePasswordAsync(request);
        isProcessing = false;

        if (response.IsSuccess)
        {
            Snackbar.Add(response.Message, Severity.Success, _ => { }, "password-change-success");
            MudDialog.Close(DialogResult.Ok(true));
            return;
        }

        feedbackMessage = response.Message;
        feedbackSeverity = Severity.Warning;
    }
}
