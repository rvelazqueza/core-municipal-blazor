@using BlazorApp.Models

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-4">
    Panel preparado para integrarse con RUC, Bienes Inmuebles, Uso de Suelo, Cobro, Notificaciones y GIS.
</MudAlert>

<MudGrid>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Licencias activas" Value="@ActiveLicenses.ToString()" Subtitle="Vigentes y aprobadas" Icon="@Icons.Material.Filled.Verified" Color="Color.Success" /></MudItem>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Solicitudes pendientes" Value="@PendingRequests.ToString()" Subtitle="Borrador, revisión o prevenidas" Icon="@Icons.Material.Filled.HourglassTop" Color="Color.Warning" /></MudItem>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Licencias vencidas" Value="@ExpiredLicenses.ToString()" Subtitle="Requieren renovación" Icon="@Icons.Material.Filled.EventBusy" Color="Color.Error" /></MudItem>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Solicitudes rechazadas" Value="@RejectedRequests.ToString()" Subtitle="Con resolución desfavorable" Icon="@Icons.Material.Filled.Block" Color="Color.Error" /></MudItem>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Uso de suelo pendiente" Value="@PendingLandUse.ToString()" Subtitle="Validación urbanística" Icon="@Icons.Material.Filled.Rule" Color="Color.Info" /></MudItem>
    <MudItem xs="12" sm="6" lg="2"><KpiCard Title="Emisión pendiente" Value="@PendingIssuance.ToString()" Subtitle="Sincronización con cobro" Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Secondary" /></MudItem>
</MudGrid>

<MudGrid Class="mt-2">
    <MudItem xs="12" lg="5">
        <MudCard Class="h-100" Outlined="true">
            <MudCardContent>
                <div class="d-flex flex-wrap justify-space-between align-center gap-2 mb-3">
                    <div>
                        <MudText Typo="Typo.h6">Resumen por estado</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Distribución operativa de licencias y solicitudes.</MudText>
                    </div>
                    <MudChip T="string" Text="Seguimiento" Color="Color.Primary" Variant="Variant.Outlined" />
                </div>
                <MudDataGrid T="ResumenEstadoPatenteViewModel" Items="StateSummary" Hover="true" Bordered="true" Dense="true" ReadOnly="true" Striped="true">
                    <Columns>
                        <PropertyColumn Property="x => x.Estado" Title="Estado" />
                        <PropertyColumn Property="x => x.Cantidad" Title="Cantidad" />
                    </Columns>
                </MudDataGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" lg="7">
        <MudCard Class="h-100" Outlined="true">
            <MudCardContent>
                <div class="d-flex flex-wrap justify-space-between align-center gap-2 mb-3">
                    <div>
                        <MudText Typo="Typo.h6">Actividad reciente</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Movimientos y resoluciones más recientes del módulo.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Text="@($"{Items.Count} expedientes en monitoreo")" Variant="Variant.Outlined" />
                </div>
                <MudTable Items="RecentActivity" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Fecha</MudTh>
                        <MudTh>Movimiento</MudTh>
                        <MudTh>Motivo</MudTh>
                        <MudTh>Usuario</MudTh>
                        <MudTh>Estado</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Fecha">@context.FechaHora.ToString("dd/MM/yyyy HH:mm")</MudTd>
                        <MudTd DataLabel="Movimiento">@context.TipoMovimiento</MudTd>
                        <MudTd DataLabel="Motivo">@context.Motivo</MudTd>
                        <MudTd DataLabel="Usuario">@context.Usuario</MudTd>
                        <MudTd DataLabel="Estado"><StatusBadge Text="@context.EstadoResultante" /></MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public List<LicenciaComercialDto> Items { get; set; } = new();

    private int ActiveLicenses => Items.Count(x => x.Estado == "Aprobado" && (!x.FechaVencimiento.HasValue || x.FechaVencimiento.Value.Date >= DateTime.Today));
    private int PendingRequests => Items.Count(x => x.Estado is "Borrador" or "En revision" or "Prevenido");
    private int ExpiredLicenses => Items.Count(x => x.Estado == "Aprobado" && x.FechaVencimiento.HasValue && x.FechaVencimiento.Value.Date < DateTime.Today);
    private int RejectedRequests => Items.Count(x => x.Estado == "Rechazado");
    private int PendingLandUse => Items.Count(x => x.PendienteUsoSuelo || x.UsoSuelo.Estado == "Pendiente");
    private int PendingIssuance => Items.Count(x => x.EmisionSemestralPendiente);

    private List<ResumenEstadoPatenteViewModel> StateSummary => Items
        .GroupBy(x => x.Estado)
        .Select(x => new ResumenEstadoPatenteViewModel { Estado = x.Key, Cantidad = x.Count() })
        .OrderByDescending(x => x.Cantidad)
        .ToList();

    private List<MovimientoPatenteDto> RecentActivity => Items
        .SelectMany(x => x.Movimientos)
        .OrderByDescending(x => x.FechaHora)
        .Take(8)
        .ToList();
}
