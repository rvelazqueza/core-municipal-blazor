@using MudBlazor

<MudCard Class="cm-empty-state h-100" Outlined="true">
    <MudCardContent Class="pa-5 pa-md-6 text-center">
        <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Large" Class="cm-empty-avatar mx-auto mb-3">
            <MudIcon Icon="@Icon" Color="Color.Inherit" />
        </MudAvatar>
        <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
        <MudText Typo="Typo.body2" Class="cm-empty-text mb-4">@Description</MudText>
        @if (!string.IsNullOrWhiteSpace(PrimaryActionHref) && !string.IsNullOrWhiteSpace(PrimaryActionText))
        {
            <MudButton Href="@PrimaryActionHref" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowForward">@PrimaryActionText</MudButton>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public string PrimaryActionText { get; set; } = string.Empty;
    [Parameter] public string PrimaryActionHref { get; set; } = string.Empty;
}
