@using MudBlazor

<MudCard Class="cm-kpi-card h-100" Outlined="true">
    <MudCardContent Class="pa-4">
        <div class="d-flex justify-space-between align-start gap-3 mb-3">
            <div class="flex-grow-1">
                <MudText Typo="Typo.caption" Class="cm-kpi-title text-uppercase">@Title</MudText>
                <MudText Typo="Typo.h4" Class="cm-kpi-value mt-2 mb-1">@Value</MudText>
                <MudText Typo="Typo.body2" Class="cm-kpi-subtitle">@Subtitle</MudText>
            </div>
            <MudAvatar Color="@Color" Variant="Variant.Filled" Size="Size.Large" Class="cm-kpi-avatar">
                <MudIcon Icon="@Icon" Color="Color.Inherit" />
            </MudAvatar>
        </div>

        <div class="cm-kpi-footer d-flex justify-space-between align-center gap-2">
            <MudText Typo="Typo.caption" Class="cm-kpi-footer-text">Indicador ejecutivo</MudText>
            <MudChip T="string" Text="Actualizado" Color="@Color" Variant="Variant.Outlined" Size="Size.Small" />
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Insights;
    [Parameter] public Color Color { get; set; } = Color.Primary;
}
