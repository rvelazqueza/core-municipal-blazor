@using BlazorApp.Models

<MudCard Outlined="true">
    <MudCardContent>
        <div class="d-flex flex-wrap justify-space-between align-center gap-2 mb-3">
            <div>
                <MudText Typo="Typo.h6">Consulta de fincas</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Resultados filtrados del catastro tributario municipal.</MudText>
            </div>
            <MudChip T="string" Text="@($"{Items.Count} registros")" Color="Color.Primary" Variant="Variant.Outlined" />
        </div>

        <MudTable Items="Items" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Número de finca</MudTh>
                <MudTh>ID predial</MudTh>
                <MudTh>Propietario</MudTh>
                <MudTh>Distrito</MudTh>
                <MudTh>Área terreno</MudTh>
                <MudTh>Valor terreno</MudTh>
                <MudTh>Valor construcción</MudTh>
                <MudTh>Valor fiscal total</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Número de finca">@context.NumeroFinca</MudTd>
                <MudTd DataLabel="ID predial">@context.IdPredial</MudTd>
                <MudTd DataLabel="Propietario">@context.PropietarioPrincipal</MudTd>
                <MudTd DataLabel="Distrito">@context.Distrito</MudTd>
                <MudTd DataLabel="Área terreno">@context.AreaTerreno.ToString("N2") m²</MudTd>
                <MudTd DataLabel="Valor terreno">@context.ValorTerreno.ToString("N2")</MudTd>
                <MudTd DataLabel="Valor construcción">@context.ValorConstruccion.ToString("N2")</MudTd>
                <MudTd DataLabel="Valor fiscal total">@context.ValorFiscalTotal.ToString("N2")</MudTd>
                <MudTd DataLabel="Estado"><StatusBadge Text="@context.Estado" /></MudTd>
                <MudTd DataLabel="Acciones">
                    <div class="d-flex flex-wrap gap-1">
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewRequested.InvokeAsync(context.Id))">Expediente</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="@(() => EditRequested.InvokeAsync(context.Id))">Editar</MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public List<BienInmuebleDto> Items { get; set; } = new();
    [Parameter] public EventCallback<int> ViewRequested { get; set; }
    [Parameter] public EventCallback<int> EditRequested { get; set; }
}
