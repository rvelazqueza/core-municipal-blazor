@page "/login"
@layout AuthLayout
@using BlazorApp.Models
@using BlazorApp.Shared
@using BlazorApp.Layout

@{
    var loginSettings = settings;
    var heroImageUrl = string.IsNullOrWhiteSpace(loginSettings.HeroImageUrl) ? loginSettings.ImagenBienvenidaUrl : loginSettings.HeroImageUrl;
}

<MudGrid Spacing="0" Class="cm-login-page min-vh-100">
    <MudItem xs="12" lg="7">
        <MudPaper Square="true" Class="cm-login-hero pa-4 pa-md-5 d-flex align-center justify-center" Style="min-height:100vh; background: linear-gradient(180deg, #07182d 0%, #0b2746 100%);">
            <div class="w-100" style="max-width: 760px;">
                <div class="text-center mb-5">
                    <div class="d-flex flex-wrap justify-center gap-2 mb-4">
                        <MudChip T="string" Text="Acceso institucional" Color="Color.Info" Variant="Variant.Filled" />
                        <MudChip T="string" Text="Operación municipal segura" Color="Color.Surface" Variant="Variant.Outlined" />
                    </div>

                    <MudText Typo="Typo.h2" Align="Align.Center" Class="text-white mb-3">@heroTitle</MudText>
                    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-3" style="color:#d7e9fb;">@heroSubtitle</MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-4" style="color:#b7d8f7; max-width: 640px; margin-inline: auto;">@heroModulesSummary</MudText>

                    <div class="d-flex flex-wrap justify-center gap-2">
                        @if (loginSettings.Beneficios.Count > 0)
                        {
                            @foreach (var beneficio in loginSettings.Beneficios)
                            {
                                <MudChip T="string" Text="@beneficio" Color="Color.Surface" Variant="Variant.Outlined" />
                            }
                        }
                        else
                        {
                            @foreach (var benefit in heroBenefits)
                            {
                                <MudChip T="string" Text="@benefit.Title" Color="Color.Surface" Variant="Variant.Outlined" />
                            }
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(heroImageUrl))
                {
                    <div style="border-radius: 28px; overflow: hidden; border: 1px solid rgba(191, 219, 254, 0.22); box-shadow: 0 26px 60px rgba(3, 10, 25, 0.34); background-color: #102944;">
                        <img src="@heroImageUrl" alt="Imagen institucional del Core Municipal Inteligente" style="display:block; width:100%; height:380px; object-fit:cover;" />
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center text-center" style="height: 380px; border-radius: 28px; border: 1px solid rgba(191, 219, 254, 0.18); background: linear-gradient(135deg, rgba(13, 44, 78, 0.96), rgba(7, 24, 45, 0.98)); box-shadow: 0 26px 60px rgba(3, 10, 25, 0.34);">
                        <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Large" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Inherit" />
                        </MudAvatar>
                        <MudText Typo="Typo.h5" Align="Align.Center" Class="text-white mb-2">Imagen institucional</MudText>
                        <MudText Typo="Typo.body2" Align="Align.Center" style="color:#c8def4; max-width: 440px;">
                            Configure una URL válida en la pantalla de configuración para visualizar aquí la imagen de bienvenida.
                        </MudText>
                    </div>
                }
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="5">
        <MudPaper Square="true" Class="cm-login-shell pa-4 pa-md-5 h-100 d-flex align-center justify-center">
            <div class="cm-login-card-wrap">
                <MudCard Outlined="true" Class="cm-login-card">
                    <MudCardContent Class="pa-4 pa-md-5">
                        <div class="d-flex justify-space-between align-start gap-3 mb-4">
                            <div>
                                <MudChip T="string" Text="Canal seguro" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="mb-2" />
                                <MudText Typo="Typo.h4">Iniciar sesión</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Acceso profesional al ecosistema municipal tributario.</MudText>
                                <MudText Typo="Typo.caption" Class="cm-login-demo-caption">Demo disponible con credenciales visibles para validación rápida.</MudText>
                            </div>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">@currentInitials</MudAvatar>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(feedbackMessage))
                        {
                            <MudAlert Severity="@feedbackSeverity" Variant="Variant.Filled" Class="mb-4">@feedbackMessage</MudAlert>
                        }

                        <MudPaper Outlined="true" Class="cm-demo-credentials pa-4 mb-4">
                            <div class="d-flex flex-wrap justify-space-between align-start gap-3 mb-3">
                                <div>
                                    <MudText Typo="Typo.subtitle1">Credenciales demo</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Usuario: @demoUser</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Contraseña: @demoPassword</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Código 2FA: @demoTwoFactorCode</MudText>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    <MudTooltip Text="Completar automáticamente las credenciales demo">
                                        <MudButton OnClick="ApplyDemoCredentials" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.AutoFixHigh">
                                            Autocompletar
                                        </MudButton>
                                    </MudTooltip>
                                    <MudTooltip Text="Copiar al portapapeles">
                                        <MudButton OnClick="CopyDemoCredentialsAsync" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy">
                                            Copiar
                                        </MudButton>
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudPaper>

                        @if (isLocked)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">
                                El acceso fue bloqueado visualmente por exceder el máximo de intentos permitidos.
                            </MudAlert>
                        }

                        <MudForm Model="loginRequest">
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudTextField T="string" @bind-Value="loginRequest.UsuarioOCorreo" Label="Usuario o correo" Variant="Variant.Outlined" Required="true" RequiredError="Ingrese su usuario o correo." FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField T="string" @bind-Value="loginRequest.Contrasena" Label="Contraseña" Variant="Variant.Outlined" InputType="InputType.Password" Required="true" RequiredError="Ingrese su contraseña." FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSwitch @bind-Value="loginRequest.Recordarme" Color="Color.Primary" Label="Recordarme" />
                                </MudItem>
                                @if (loginSettings.HabilitarTwoFactor)
                                {
                                    <MudItem xs="12" md="6">
                                        <MudSwitch @bind-Value="loginRequest.SolicitarTwoFactor" Color="Color.Info" Label="Verificación 2FA" />
                                    </MudItem>
                                }
                                @if (loginRequest.SolicitarTwoFactor && loginSettings.HabilitarTwoFactor)
                                {
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="twoFactorRequest.Codigo" Label="Código 2FA" Variant="Variant.Outlined" HelperText="@twoFactorHelperText" FullWidth="true" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudForm>

                        <div class="d-flex flex-column gap-3 mt-4">
                            <MudButton OnClick="HandleLoginAsync" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@(isProcessing || isLocked)">
                                @if (isProcessing)
                                {
                                    <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" />
                                    <MudText Inline="true">Validando acceso</MudText>
                                }
                                else
                                {
                                    <MudText Inline="true">Iniciar sesión</MudText>
                                }
                            </MudButton>

                            @if (loginSettings.HabilitarFirmaDigital)
                            {
                                <MudButton OnClick="HandleDigitalSignatureAsync" Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Disabled="@(isProcessing || isLocked)" StartIcon="@Icons.Material.Filled.Verified">
                                    Ingresar con firma digital
                                </MudButton>
                            }

                            @if (loginRequest.SolicitarTwoFactor && loginSettings.HabilitarTwoFactor)
                            {
                                <MudButton OnClick="HandleTwoFactorAsync" Variant="Variant.Text" Color="Color.Info" FullWidth="true" Disabled="@(isProcessing || isLocked)">
                                    Confirmar verificación 2FA
                                </MudButton>
                            }
                        </div>

                        <div class="d-flex flex-wrap justify-space-between align-center gap-2 mt-4">
                            <MudLink Href="/configuracion">Olvidé mi contraseña</MudLink>
                            <MudChip T="string" Text="@($"Intentos fallidos: {failedAttempts}/{loginSettings.MaxIntentosFallidos}")" Color="Color.Warning" Variant="Variant.Outlined" />
                        </div>
                    </MudCardContent>
                </MudCard>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>
